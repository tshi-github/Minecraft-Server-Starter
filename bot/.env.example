# Discordボットのトークン (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=

# 操作パネルを送信するDiscordのチャンネルID(チャンネルを右クリック→IDをコピー)
CHANNEL_ID=

# ローカルエージェントとの接続を認証するための共有シークレット。
# 自分で適当な長くてランダムな文字列を決めてこことagent/.envの両方に同じ値を設定する
AGENT_TOKEN=

# 起動したいPCのMACアドレス (例: 20:DE:20:DE:20:DE)
MAC_ADDRESS=

# WOLパケットを送る宛先。自宅のDDNSホスト名を設定する(ルーターでポート転送設定が必要)
WOL_TARGET_HOST=yourhouse.ddns.net

# WOLパケットの宛先ポート。ルーターのポート転送設定と合わせる(未指定なら9)
WOL_TARGET_PORT=9

# Renderが自動でPORTを渡すので通常は変更不要(ローカル動作確認用の既定値)
PORT=3000
