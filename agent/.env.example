# RenderにデプロイしたBotのWebSocketエンドポイント
# 例: Render URLが https://your-app.onrender.com なら wss://your-app.onrender.com/agent
BOT_WS_URL=wss://your-app.onrender.com/agent

# bot側の.envに設定したAGENT_TOKENと必ず同じ値にする
AGENT_TOKEN=

# Minecraftのserver.propertiesで設定したRCON情報
MC_RCON_HOST=127.0.0.1
MC_RCON_PORT=25575
MC_RCON_PASSWORD=

# サーバー起動用batファイルの絶対パス
START_BAT_PATH=C:\minecraft\server\start.bat

# batファイルを実行する際の作業ディレクトリ(サーバーのフォルダ)
START_BAT_CWD=C:\minecraft\server

# 自動シャットダウン機能(任意)。使う場合はtrueにする
AUTO_SHUTDOWN_ENABLED=false

# 自動シャットダウンを判定する時刻(24時間表記。例: 6 = 朝6時)
AUTO_SHUTDOWN_HOUR=6
